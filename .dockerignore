# Dependencies & caches
.venv/
__pycache__/
.ruff_cache/

# IDE
.idea/

# Runtime database files (container creates its own)
*.db
*.db-shm
*.db-wal

# Docker / Git
.git/
.gitignore
.dockerignore
Dockerfile
docker-compose.yml

# Docs — the Dockerfile COPYs README.md and LICENSE into the builder
# stage because pyproject.toml references them via `readme` and
# `license = { file = "LICENSE" }`.  Excluding them here silently breaks
# `docker build` with "file not found".
*.md
!README.md
# (LICENSE intentionally not listed — it must ship with the image.)
