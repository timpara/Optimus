# ─────────────────────────────────────────────────────────────────────────────
# gridplay — Battery Trader Sim — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#   1. Copy this file to `.env`
#   2. Set GRIDPLAY_CLASS_PASSWORD and GRIDPLAY_ADMIN_KEY to your own values
#      (the server refuses to start without them)
#   3. Optionally override any of the other variables below
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets (REQUIRED) ──
# The server will refuse to start if either of these is unset or empty.
# Use long, unique values — these are the only thing protecting your
# classroom instance from unauthorized access.
GRIDPLAY_CLASS_PASSWORD=change-me-for-each-class
GRIDPLAY_ADMIN_KEY=change-me-and-keep-secret

# ── Game settings ──
# GRIDPLAY_TICK_INTERVAL=1.0

# ── Battery specs ──
# GRIDPLAY_BATTERY_MAX_MWH=50000
# GRIDPLAY_BATTERY_MAX_MW=10000
# GRIDPLAY_BATTERY_START_MWH=25000

# ── Economy ──
# GRIDPLAY_STARTING_CASH=0.0
# GRIDPLAY_STARTING_REF_PRICE=45.0

# ── Database (inside the container; normally no need to change) ──
# GRIDPLAY_DB_PATH=/data/battery_trader.db
